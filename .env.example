# Database
DATABASE_URL=postgresql+asyncpg://insurtech:insurtech@localhost:5432/insurtech

# Redis
REDIS_URL=redis://localhost:6379

# AI (OpenAI)
OPENAI_API_KEY=sk-...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=newsletter@insurtech.news
RESEND_FROM_NAME=InsurTech Intelligence

# Auth
SECRET_KEY=your-secret-key-min-32-chars
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (get from console.cloud.google.com → APIs → Credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin
ADMIN_EMAIL=admin@insurtech.news

# Environment
ENVIRONMENT=development
